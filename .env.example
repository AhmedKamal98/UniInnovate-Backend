# Database
DATABASE_URL=postgresql://uniinnovate:uniinnovate@localhost:5432/uniinnovate?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-to-another-random-256-bit-secret
JWT_REFRESH_EXPIRES_IN=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=uniinnovate-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# SMTP (Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App
CORS_ORIGINS=http://localhost:5173
NODE_ENV=development
PORT=3000
